{
  "info": {
    "_postman_id": "spv-fyp-api-collection",
    "name": "Smart Property Valuer API",
    "description": "Postman collection for Smart Property Valuer FYP API testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "health"
          ]
        },
        "description": "Check whether the API, database, and model are available."
      },
      "response": []
    },
    {
      "name": "Predict Property Price",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"Built_Up_SF\": 1200,\n  \"Land_Size\": 1400,\n  \"Bedroom\": 3,\n  \"Bathroom\": 2,\n  \"Car_Park\": 1,\n  \"Furnishing\": 2,\n  \"Tenure\": 2,\n  \"Property_Type\": 1,\n  \"Unit_Type\": 1,\n  \"state\": \"Selangor\",\n  \"area_text\": \"Shah Alam\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/predict",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "predict"
          ]
        },
        "description": "Predict property price and return recommended listings."
      },
      "response": []
    },
    {
      "name": "Search Properties",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/search?state=Selangor&min_price=200000&max_price=800000&property_type=1&bedroom=3&page=1&per_page=10",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "search"
          ],
          "query": [
            {
              "key": "state",
              "value": "Selangor"
            },
            {
              "key": "min_price",
              "value": "200000"
            },
            {
              "key": "max_price",
              "value": "800000"
            },
            {
              "key": "property_type",
              "value": "1"
            },
            {
              "key": "bedroom",
              "value": "3"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "per_page",
              "value": "10"
            }
          ]
        },
        "description": "Search property listings from SQL with optional filters."
      },
      "response": []
    },
    {
      "name": "Get Property Details",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/property/2265",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "property",
            "2265"
          ]
        },
        "description": "Get one property record by database ID. Example: 2265 = P2265."
      },
      "response": []
    },
    {
      "name": "Get Model Metrics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/model/metrics",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "model",
            "metrics"
          ]
        },
        "description": "Return model performance metrics and tuned parameter values."
      },
      "response": []
    }
  ]
}
